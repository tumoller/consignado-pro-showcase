# Variáveis do container wuzapi (docker-compose local/VPS OU service da Railway).
# Copie para .env e preencha. NÃO commitar o .env real.

# Token de admin da wuzapi — gere aleatório e longo, ex: openssl rand -hex 24
WUZAPI_ADMIN_TOKEN=

# Só se usar Postgres (senão a wuzapi usa SQLite no volume dbdata)
DB_PASSWORD=
