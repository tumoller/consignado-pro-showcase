# Variáveis do container wuzapi (docker-compose local OU service da Railway).
# Corrigido em 2026-07-12: esta versão da wuzapi EXIGE Postgres (sem SQLite).
# Copie para .env e preencha. NÃO commitar o .env real.

# --- obrigatórios ---
# Token de admin — gere aleatório: openssl rand -hex 24
WUZAPI_ADMIN_TOKEN=

# Chave AES-256 — precisa ter EXATAMENTE 32 caracteres. Gere: openssl rand -hex 16
WUZAPI_GLOBAL_ENCRYPTION_KEY=

DB_USER=wuzapi
DB_PASSWORD=
DB_NAME=wuzapi

# --- recomendado ---
# Assina os webhooks enviados pela wuzapi (min. 32 chars). Gere: openssl rand -hex 20
WUZAPI_GLOBAL_HMAC_KEY=
